# Database
DATABASE_URL=

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Admin seed credentials (used by `npm run db:seed`)
ADMIN_EMAIL=admin@factify.com
ADMIN_PASSWORD=
ADMIN_NAME=Admin User

# OpenAI (required for AI verification verdicts)
OPENAI_API_KEY=

# News & search APIs
NEWS_API_KEY=
GNEWS_API_KEY=
BING_SEARCH_API_KEY=
TAVILY_API_KEY=

# Optional: Cloudinary for media uploads
CLOUDINARY_URL=
